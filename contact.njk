---
layout: null
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Contact Us — Heartland Mini Golf</title>
<link rel="icon" type="image/png" href="data:image/png;base64,">
<link rel="apple-touch-icon" href="data:image/png;base64,">
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
{% raw %}<style>
*{box-sizing:border-box;margin:0;padding:0;}
:root{--green:#2e7d4f;--green-light:#d0edd9;--green-bg:#f4fbf7;--text:#111;--muted:#444;--border:#ddd;}
html,body{background:#fff;font-family:'DM Sans',sans-serif;color:var(--text);}
body{max-width:960px;margin:0 auto;}

/* NAV */
.hmg-nav{display:flex;align-items:center;justify-content:space-between;padding:1.1rem 2rem;border-bottom:1px solid var(--border);background:#fff;position:sticky;top:0;z-index:50;}
.hmg-logo{font-family:'DM Serif Display',serif;font-size:18px;color:#111;text-decoration:none;}
.hmg-logo span{color:var(--green);}
.hmg-nav-links{display:flex;gap:1.8rem;list-style:none;}
.hmg-nav-links a{font-size:12px;font-weight:500;text-decoration:none;color:#111;letter-spacing:.5px;text-transform:uppercase;transition:color .15s;}
.hmg-nav-links a:hover{color:var(--green);}
.hmg-nav-right{display:flex;align-items:center;gap:10px;}
.hmg-nav-cta{font-size:13px;font-weight:500;padding:8px 20px;border-radius:100px;background:var(--green);color:#fff;text-decoration:none;border:none;cursor:pointer;font-family:'DM Sans',sans-serif;}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:4px;background:none;border:none;}
.hamburger span{display:block;width:22px;height:2px;background:#111;border-radius:2px;transition:all .25s;}
.hamburger.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
.hamburger.open span:nth-child(2){opacity:0;}
.hamburger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}
.mobile-menu{display:none;flex-direction:column;background:#fff;border-bottom:1px solid var(--border);padding:1rem 2rem 1.5rem;gap:1rem;}
.mobile-menu.open{display:flex;}
.mobile-menu a{font-size:15px;font-weight:500;text-decoration:none;color:#111;padding:.5rem 0;border-bottom:1px solid #eee;}
.mobile-menu a:last-child{border-bottom:none;}
.mobile-menu .mob-cta{display:block;text-align:center;margin-top:.5rem;padding:12px;border-radius:100px;background:var(--green);color:#fff;font-size:15px;font-weight:500;text-decoration:none;}

/* HAMBURGER DROPDOWN */
.hmg-hamburger-wrap{position:relative;}
.hmg-hamburger-btn{display:flex;flex-direction:column;gap:5px;cursor:pointer;padding:6px;background:none;border:none;flex-shrink:0;}
.hmg-hamburger-btn span{display:block;width:22px;height:2px;background:#111;border-radius:2px;transition:all .25s;}
.hmg-hamburger-btn.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
.hmg-hamburger-btn.open span:nth-child(2){opacity:0;}
.hmg-hamburger-btn.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}
.hmg-dropdown{display:none;position:absolute;top:calc(100% + 10px);right:0;background:#fff;border:2px solid #ddd;border-radius:12px;min-width:220px;box-shadow:0 8px 30px rgba(0,0,0,.12);overflow:hidden;z-index:200;}
.hmg-dropdown.open{display:block;}
.hmg-dropdown a{display:flex;align-items:center;gap:10px;padding:13px 18px;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:500;color:#111;text-decoration:none;border-bottom:1px solid #f0f0f0;transition:background .15s;}
.hmg-dropdown a:last-child{border-bottom:none;}
.hmg-dropdown a:hover{background:#f4fbf7;color:var(--green);}
.hmg-dropdown-icon{width:18px;height:18px;flex-shrink:0;}
.hmg-dropdown-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:#aaa;padding:10px 18px 6px;display:block;}

/* HERO BANNER */
.contact-hero{background:var(--green);padding:3.5rem 2.5rem;text-align:center;color:#fff;}
.contact-hero p{font-size:11px;font-weight:500;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.7);margin-bottom:.75rem;}
.contact-hero h1{font-family:'DM Serif Display',serif;font-size:42px;letter-spacing:-.5px;margin-bottom:.75rem;}
.contact-hero span{font-size:15px;color:rgba(255,255,255,.8);line-height:1.6;}

/* MAIN LAYOUT */
.contact-body{display:grid;grid-template-columns:1fr 1.1fr;gap:0;border-bottom:1px solid var(--border);}

/* LEFT — INFO */
.contact-info{padding:3rem 2.5rem;border-right:1px solid var(--border);}
.info-block{margin-bottom:2.5rem;}
.info-block:last-child{margin-bottom:0;}
.info-eyebrow{font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--green);margin-bottom:.75rem;}
.info-block h2{font-family:'DM Serif Display',serif;font-size:22px;margin-bottom:1rem;color:#111;}

.info-item{display:flex;align-items:flex-start;gap:12px;margin-bottom:1rem;}
.info-item:last-child{margin-bottom:0;}
.info-icon{width:36px;height:36px;border-radius:9px;background:var(--green-bg);border:1px solid var(--green-light);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px;}
.info-item-text p{font-size:13px;color:var(--muted);line-height:1.6;}
.info-item-text a{font-size:14px;font-weight:500;color:#111;text-decoration:none;display:block;margin-bottom:2px;}
.info-item-text a:hover{color:var(--green);}

/* HOURS TABLE */
.hours-table{width:100%;border-collapse:collapse;margin-top:.5rem;}
.hours-table tr{border-bottom:1px solid #f0f0f0;}
.hours-table tr:last-child{border-bottom:none;}
.hours-table td{padding:8px 0;font-size:13px;}
.hours-table td:first-child{color:var(--muted);font-weight:500;}
.hours-table td:last-child{text-align:right;font-weight:600;color:#111;}

/* SOCIAL ROW */
.social-row{display:flex;gap:10px;margin-top:.5rem;}
.social-btn{display:inline-flex;align-items:center;gap:8px;padding:9px 16px;border-radius:100px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;text-decoration:none;border:2px solid var(--border);color:#111;background:#fff;transition:border-color .15s,box-shadow .15s;}
.social-btn:hover{border-color:#bbb;box-shadow:0 2px 8px rgba(0,0,0,.08);}

/* MAP */
.contact-map{border-radius:10px;overflow:hidden;border:2px solid var(--border);height:200px;margin-top:1.5rem;}
.contact-map iframe{width:100%;height:100%;border:none;display:block;}

/* RIGHT — FORM */
.contact-form-wrap{padding:3rem 2.5rem;background:#fafafa;}
.form-eyebrow{font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--green);margin-bottom:.75rem;}
.contact-form-wrap h2{font-family:'DM Serif Display',serif;font-size:26px;margin-bottom:.5rem;}
.contact-form-wrap>p{font-size:13px;color:var(--muted);margin-bottom:1.75rem;line-height:1.6;}

.form-group{margin-bottom:14px;}
.form-group label{display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#888;margin-bottom:5px;}
.form-group input,.form-group textarea,.form-group select{width:100%;padding:11px 14px;border:2px solid var(--border);border-radius:9px;font-family:'DM Sans',sans-serif;font-size:14px;color:#111;outline:none;background:#fff;transition:border-color .15s;}
.form-group input:focus,.form-group textarea:focus,.form-group select:focus{border-color:var(--green);}
.form-group textarea{resize:vertical;min-height:110px;line-height:1.6;}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.form-submit{width:100%;padding:13px;border-radius:100px;background:var(--green);color:#fff;border:none;cursor:pointer;font-family:'DM Sans',sans-serif;font-size:15px;font-weight:600;margin-top:6px;transition:opacity .15s;}
.form-submit:hover{opacity:.88;}

/* SUCCESS / ERROR messages */
#form-success{display:none;background:#d0edd9;color:#1a5c33;border-radius:10px;padding:14px 18px;font-size:14px;font-weight:500;margin-top:14px;text-align:center;}
#form-error{display:none;background:#fde8e8;color:#a32d2d;border-radius:10px;padding:14px 18px;font-size:14px;font-weight:500;margin-top:14px;text-align:center;}

/* INQUIRY TYPE */
.inquiry-chips{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:14px;}
.inquiry-chip{padding:7px 14px;border-radius:100px;border:2px solid var(--border);font-size:12.5px;font-weight:500;cursor:pointer;transition:all .15s;color:#555;background:#fff;user-select:none;}
.inquiry-chip.selected{border-color:var(--green);background:var(--green-bg);color:var(--green);}

/* FOOTER */
.hmg-footer{padding:2.25rem 2.5rem;display:grid;grid-template-columns:1.5fr 1fr 1fr;gap:2rem;border-top:2px solid var(--border);background:#fff;}
.footer-brand{font-family:'DM Serif Display',serif;font-size:18px;margin-bottom:.65rem;color:#111;}
.footer-brand span{color:var(--green);}
.footer-desc{font-size:12.5px;color:#555;line-height:1.7;}
.footer-head{font-size:10px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:#111;margin-bottom:.85rem;}
.footer-links{display:flex;flex-direction:column;gap:7px;list-style:none;}
.footer-links a{font-size:13px;color:#555;text-decoration:none;}
.footer-links a:hover{color:var(--green);}
.footer-links li{font-size:12px;color:#555;}
.footer-bottom{border-top:1px solid var(--border);padding:.9rem 2.5rem;display:flex;justify-content:space-between;align-items:center;background:#fff;}
.footer-copy{font-size:11.5px;color:#777;}
.footer-social{display:flex;gap:12px;}
.footer-social a{font-size:11.5px;font-weight:600;color:#777;text-decoration:none;}
.footer-social a:hover{color:var(--green);}

/* BACK LINK */
.back-bar{padding:.85rem 2.5rem;border-bottom:1px solid var(--border);background:#fafafa;}
.back-link{display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:500;color:var(--muted);text-decoration:none;transition:color .15s;}
.back-link:hover{color:var(--green);}

/* MOBILE */
@media(max-width:700px){
  body{max-width:100%;}
  .hmg-nav{padding:.9rem 1.25rem;}
  .hmg-nav-links{display:none;}
  .hmg-nav-cta{display:none;}
  .hmg-hamburger-wrap{display:none;}
  .hamburger{display:flex;}
  .contact-hero{padding:2.5rem 1.5rem;}
  .contact-hero h1{font-size:32px;}
  .contact-body{grid-template-columns:1fr;}
  .contact-info{border-right:none;border-bottom:1px solid var(--border);padding:2rem 1.5rem;}
  .contact-form-wrap{padding:2rem 1.5rem;}
  .form-row{grid-template-columns:1fr;}
  .hmg-footer{grid-template-columns:1fr;padding:2rem 1.5rem;}
  .footer-bottom{flex-direction:column;gap:.75rem;text-align:center;padding:1rem 1.5rem;}
  .back-bar{padding:.85rem 1.5rem;}
}
</style>{% endraw %}
<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
