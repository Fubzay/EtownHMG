{% raw %}
<script>
// Hamburger dropdown
document.getElementById('hmg-menu-btn').addEventListener('click', function() {
  this.classList.toggle('open');
  document.getElementById('hmg-dropdown').classList.toggle('open');
});
document.addEventListener('click', function(e) {
  var wrap = document.querySelector('.hmg-hamburger-wrap');
  if (wrap && !wrap.contains(e.target)) {
    document.getElementById('hmg-menu-btn').classList.remove('open');
    document.getElementById('hmg-dropdown').classList.remove('open');
  }
});

// Mobile menu
function toggleMenu() {
  document.getElementById('hamburger').classList.toggle('open');
  document.getElementById('mobile-menu').classList.toggle('open');
}
function closeMenu() {
  document.getElementById('hamburger').classList.remove('open');
  document.getElementById('mobile-menu').classList.remove('open');
}

// Inquiry chip selector
function selectChip(el, value) {
  document.querySelectorAll('.inquiry-chip').forEach(function(c) { c.classList.remove('selected'); });
  el.classList.add('selected');
  document.getElementById('inquiry-type').value = value;
}

// Formspree AJAX submission
document.getElementById('contact-form').addEventListener('submit', function(e) {
  e.preventDefault();
  var form = this;
  var btn = form.querySelector('.form-submit');
  var success = document.getElementById('form-success');
  var error = document.getElementById('form-error');
  btn.textContent = 'Sending...';
  btn.disabled = true;
  fetch('https://formspree.io/f/xeenoken', {
    method: 'POST',
    body: new FormData(form),
    headers: { 'Accept': 'application/json' }
  }).then(function(r) {
    if (r.ok) {
      form.reset();
      success.style.display = 'block';
      error.style.display = 'none';
      btn.textContent = 'Message Sent!';
    } else {
      error.style.display = 'block';
      success.style.display = 'none';
      btn.textContent = 'Send Message';
      btn.disabled = false;
    }
  }).catch(function() {
    error.style.display = 'block';
    success.style.display = 'none';
    btn.textContent = 'Send Message';
    btn.disabled = false;
  });
});
</script>
{% endraw %}
</body>
</html>