        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" fill="#fff"/></svg>
        Get Directions
      </a>
    </div>

  </div>

  <!-- RIGHT — FORM -->
  <div class="contact-form-wrap">
    <p class="form-eyebrow">Send a message</p>
    <h2>We'd love to hear from you</h2>
    <p>Fill out the form below and we'll get back to you within 24 hours.</p>

    <p style="font-size:12px;color:#888;margin-bottom:14px;margin-top:-8px;">What are you reaching out about?</p>
    <div class="inquiry-chips">
      <div class="inquiry-chip selected" onclick="selectChip(this,'General Question')">General Question</div>
      <div class="inquiry-chip" onclick="selectChip(this,'Party Room Booking')">Party Room Booking</div>
      <div class="inquiry-chip" onclick="selectChip(this,'Event Inquiry')">Event Inquiry</div>
      <div class="inquiry-chip" onclick="selectChip(this,'Feedback')">Feedback</div>
      <div class="inquiry-chip" onclick="selectChip(this,'Other')">Other</div>
    </div>

    <form id="contact-form" action="https://formspree.io/f/xeenoken" method="POST">
      <input type="hidden" name="inquiry_type" id="inquiry-type" value="General Question">
      <div class="form-row">
        <div class="form-group">
          <label>First Name *</label>
          <input type="text" name="first_name" placeholder="John" required>
        </div>
        <div class="form-group">
          <label>Last Name *</label>
          <input type="text" name="last_name" placeholder="Smith" required>
        </div>
      </div>
      <div class="form-group">
        <label>Email Address *</label>
        <input type="email" name="email" placeholder="john@example.com" required>
      </div>
      <div class="form-group">
        <label>Phone Number</label>
        <input type="tel" name="phone" placeholder="(270) 555-0000">
      </div>
      <div class="form-group">
        <label>Message *</label>
        <textarea name="message" placeholder="Tell us what's on your mind..." required></textarea>
      </div>
      <button type="submit" class="form-submit">Send Message</button>
      <div id="form-success">&#10003; Message sent! We'll be in touch within 24 hours.</div>
      <div id="form-error">Something went wrong. Please try again or call us at {{ contact.contact.phone }}.</div>
    </form>
  </div>

</div>

